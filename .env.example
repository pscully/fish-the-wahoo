# Fish The Wahoo — frontend environment variables.
# Copy to .env and fill in real values. .env is gitignored.
# Keys prefixed with VITE_ are exposed to the client bundle.

# Supabase (anon key is safe to expose)
VITE_SUPABASE_URL=https://cidzchicqmcdpymgxhbm.supabase.co
VITE_SUPABASE_ANON_KEY=

# Stripe publishable key (safe to expose — belongs in the browser)
# Use pk_test_... during development, pk_live_... at launch.
VITE_STRIPE_PUBLISHABLE_KEY=

# Google Business Profile review URL — rendered as a CTA on the booking
# thank-you page. Same value as the GBP_REVIEW_URL edge-function secret.
VITE_GBP_REVIEW_URL=

# ---
# The variables below are for Supabase edge functions and must be set via:
#   supabase secrets set KEY=value
# They do NOT belong in this file. Listed here for documentation only.
#
# STRIPE_SECRET_KEY=sk_test_...               # server-side Stripe
# STRIPE_WEBHOOK_SECRET=whsec_...             # webhook signature verification
# POSTMARK_SERVER_TOKEN=<uuid>                # Postmark transactional server token
# POSTMARK_FROM_EMAIL=bookings@fishthewahoo.com   # must be on verified Postmark domain
# ADMIN_EMAILS=titleist123@gmail.com,patrick@possibleweb.com
# GBP_REVIEW_URL=https://g.page/...           # Google Business Profile review link
# PUBLIC_SITE_URL=https://fishthewahoo.com    # used in email links
